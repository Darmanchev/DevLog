SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Local default: leave DATABASE_URL empty to use SQLite.
DATABASE_URL=

# Production PostgreSQL example:
# DATABASE_URL=postgres://blog_user:strong_password@127.0.0.1:5432/blog_db?sslmode=require
# DB_CONN_MAX_AGE=60

# Production HTTPS/security. Enable these after HTTPS is configured.
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
